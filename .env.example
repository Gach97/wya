# DLP System Environment Configuration
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env with real credentials to git!

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=dlp_db

# Tebi S3 Configuration (Optional - leave blank to use local storage only)
ENABLE_TEBI_STORAGE=false
TEBI_KEY=
TEBI_SECRET=
TEBI_ENDPOINT=https://s3.tebi.io
TEBI_REGION=de

# Application Settings
APP_DEBUG=false
SESSION_TIMEOUT=3600

# Encryption/Security
APP_KEY=your-secret-key-here-change-this
